{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resend Desk",
  "version": "0.3.0",
  "identifier": "com.uf4over.resenddesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "Resend Desk",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    }
  }
}
